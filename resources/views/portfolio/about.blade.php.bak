.ab-story-text p { color: var(--pg-text-sec); line-height: 1.8; margin-bottom: 1rem; font-size: 0.95rem; }
.ab-story-img { border-radius: 20px; overflow: hidden; background: color-mix(in srgb, var(--pg-accent) 10%, var(--pg-card)); border: 1px solid var(--pg-border); height: 320px; display: flex; align-items: center; justify-content: center; }
